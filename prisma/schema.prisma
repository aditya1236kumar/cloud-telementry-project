generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String      @unique
  password    String
  bio         String?
  avatarUrl   String?
  createdAt   DateTime    @default(now())
  telemetry   Telemetry[]
}

model Telemetry {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])
  userId       String   @db.ObjectId
  serviceUrl   String
  name         String
  dailyUsage   Float
  monthlyUsage Float
  yearlyUsage  Float
  growthRate   Float
  createdAt    DateTime @default(now())
}
