generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          Int         @id @default(autoincrement())
  name        String
  email       String      @unique
  password    String
  bio         String?
  avatarUrl   String?
  createdAt   DateTime    @default(now())
  telemetry   Telemetry[]
}

model Telemetry {
  id           Int      @id @default(autoincrement())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int
  serviceUrl   String
  name         String
  dailyUsage   Float
  monthlyUsage Float
  yearlyUsage  Float
  growthRate   Float
  createdAt    DateTime @default(now())
}
